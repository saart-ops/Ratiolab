  "claim_verification": [
    {
      "claim": "The DOJ and 17 state attorneys general filed a civil antitrust lawsuit against three of the nation's largest egg producers in 2026.",
      "matches": []
    },
    {
      "claim": "The three companies named in the lawsuit are Cal-Maine Foods, Versova, and Hickman's Egg Ranch.",
      "matches": []
    },
    {
      "claim": "The producers allegedly coordinated their bidding on the Egg Clearinghouse Inc. platform to artificially inflate prices.",
      "matches": []
    },
    {
      "claim": "The manipulation targeted Urner Barry, a market reporting company whose benchmark prices are used in contracts throughout the egg industry.",
      "matches": []
    },
    {
      "claim": "The alleged price coordination took place between June 2022 and March 2025.",
      "matches": []
    },
    {
      "claim": "The three companies agreed to collectively pay $3.3 million to the participating states.",
      "matches": []
    },
    {
      "claim": "The $3.3 million fine was described as a tiny fraction of the profits made during the price-fixing period.",
      "matches": []
    },
    {
      "claim": "The producers agreed to donate 53 million eggs to food banks and nonprofit organizations as part of the settlement.",
      "matches": []
    },
    {
      "claim": "None of the three companies admitted any wrongdoing or liability as part of the settlement.",
      "matches": []
    },
    {
      "claim": "The settlement includes a five-year compliance term requiring antitrust compliance programs.",
      "matches": []
    },
    {
      "claim": "The companies are required to appoint a DOJ-approved compliance officer under the settlement terms.",
      "matches": []
    },
    {
      "claim": "Cal-Maine Foods is the largest producer and distributor of fresh shell eggs in the United States.",
      "matches": []
    },
    {
      "claim": "Cal-Maine Foods reported net income of approximately $758 million in fiscal year 2023 during the period of record egg prices.",
      "matches": []
    },
    {
      "claim": "Cal-Maine Foods reported record net income of approximately $1.2 billion in fiscal year 2025.",
      "matches": []
    },
    {
      "claim": "The companies claimed that price surges were driven by avian influenza outbreaks, supply disruptions, and inflation, not coordination.",
      "matches": []
    },
    {
      "claim": "Egg producers reported record profits during the price-fixing period.",
      "matches": []
